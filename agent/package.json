{
  "name": "mydex-agent",
  "version": "0.3.0",
  "description": "MyDex Desktop Agent - Employee monitoring client",
  "author": "MyDex <support@antifascist.work>",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "start:hidden": "electron . --hidden",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "active-win": "^8.1.0",
    "electron-store": "^8.2.0",
    "node-cron": "^3.0.3",
    "systeminformation": "^5.31.5"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "work.antifascist.mydex-agent",
    "productName": "MyDex Agent",
    "artifactName": "MyDex-Agent-Setup-${version}.${ext}",
    "win": {
      "target": [
        "nsis",
        "msi",
        "zip"
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "requireAdministrator",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "runAfterFinish": true,
      "installerIcon": "assets/icon.ico",
      "include": "installer.nsh"
    },
    "mac": {
      "target": [
        "dmg",
        "pkg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "zip"
      ],
      "icon": "assets/icon.png"
    }
  }
}
