ex-col sm:flex-row items-center gap-4\"><div class=\"flex items-center gap-3\"><div class=\"p-2 rounded-lg bg-indigo-100 dark:bg-indigo-900/50\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-calculator h-5 w-5 text-indigo-600 dark:text-indigo-400\" aria-hidden=\"true\"><rect width=\"16\" height=\"20\" x=\"4\" y=\"2\" rx=\"2\"></rect><line x1=\"8\" x2=\"16\" y1=\"6\" y2=\"6\"></line><line x1=\"16\" x2=\"16\" y1=\"14\" y2=\"18\"></line><path d=\"M16 10h.01\"></path><path d=\"M12 10h.01\"></path><path d=\"M8 10h.01\"></path><path d=\"M12 14h.01\"></path><path d=\"M8 14h.01\"></path><path d=\"M12 18h.01\"></path><path d=\"M8 18h.01\"></path></svg></div><div><div class=\"text-sm font-medium\">Team Size</div><div class=\"text-xs text-muted-foreground\">Drag to estimate your cost</div></div></div><div class=\"flex-1 w-full\"><input type=\"range\" min=\"5\" max=\"1000\" class=\"w-full h-2 bg-gray-200 dark:bg-gray-700 rounded-lg appearance-none cursor-pointer accent-indigo-600\" value=\"50\"/><div class=\"flex justify-between mt-1 px-0.5\"><button class=\"text-[10px] text-muted-foreground\">10</button><button class=\"text-[10px] text-muted-foreground\">25</button><button class=\"text-[10px] text-indigo-600 dark:text-indigo-400 font-bold\">50</button><button class=\"text-[10px] text-muted-foreground\">100</button><button class=\"text-[10px] text-muted-foreground\">250</button><button class=\"text-[10px] text-muted-foreground\">500</button><button class=\"text-[10px] text-muted-foreground\">1000</button></div></div><div class=\"text-center min-w-[100px]\"><div class=\"text-3xl font-bold text-indigo-600 dark:text-indigo-400\">50</div><div class=\"text-xs text-muted-foreground\">employees</div></div></div><div class=\"mt-4 pt-4 border-t flex items-center justify-between\"><div class=\"flex items-center gap-