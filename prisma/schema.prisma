generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// MULTI-TENANCY & AUTH
// ============================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  settings  Json     @default("{}")
  requireAgentForClock Boolean @default(false)
  defaultMonitoringMode MonitoringMode @default(ALWAYS)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  monitoringChangeLogs MonitoringChangeLog[]
  projects         Project[]
  dlpPolicies      DlpPolicy[]
  scheduledReports ScheduledReport[]
  reportHistories  ReportHistory[]
  departments      Department[]
  hostGroups       HostGroup[]
  domainBlocklists DomainBlocklist[]
  agentApiKeys     AgentApiKey[]
  agentPolicies    AgentPolicy[]
  ssoProviders     SsoProvider[]
  mdmProviders     MdmProvider[]
  patchNotes       PatchNote[]
  softwareLicenses SoftwareLicense[]
  itBudgetEntries  ItBudgetEntry[]
  energyReadings   EnergyReading[]
  sustainabilityGoals SustainabilityGoal[]
  notifications    Notification[]
  integrations     Integration[]
  scimTokens       ScimToken[]
  scimEvents       ScimEvent[]
}

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  name           String
  passwordHash   String?
  image          String?
  role           Role       @default(EMPLOYEE)
  status         UserStatus @default(ACTIVE)
  organizationId String
  department     String?
  jobTitle       String?
  managerId      String?
  monitoringPaused Boolean  @default(false)
  monitoringPausedAt DateTime?
  monitoringMode MonitoringMode @default(ALWAYS)
  canToggleMonitoring Boolean @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id])
  manager       User?         @relation("ManagerReports", fields: [managerId], references: [id])
  directReports User[]        @relation("ManagerReports")
  departmentRef Department?   @relation("UserDepartment", fields: [departmentId], references: [id])
  departmentId  String?

  accounts          Account[]
  sessions          Session[]
  timeEntries       TimeEntry[]
  attendanceRecords AttendanceRecord[]
  leaveRequests     LeaveRequest[]
  activityEvents    ActivityEvent[]
  activitySummaries ActivitySummary[]
  assignedTasks     Task[]          @relation("TaskAssignee")
  createdTasks      Task[]          @relation("TaskCreator")
  securityAlerts    SecurityAlert[]
  auditLogs         AuditLog[]
  agentDevices      AgentDevice[]
  mfaCredential     MfaCredential?
  activeSessions    ActiveSession[]
  submittedTickets  SupportTicket[]  @relation("TicketSubmitter")
  assignedTickets   SupportTicket[]  @relation("TicketAssignee")
  ticketMessages    TicketMessage[]
  boardingTasks     BoardingTask[]   @relation("BoardingUser")
  boardingCompleted BoardingTask[]   @relation("BoardingCompletedBy")
  generatedReports  ReportHistory[]  @relation("generatedReports")
  monitoringChangeLogs MonitoringChangeLog[] @relation("MonitoringUser")
  monitoringChangesBy  MonitoringChangeLog[] @relation("MonitoringChangedBy")
  patchNotes           PatchNote[]           @relation("PatchNoteAuthor")
  notifications        Notification[]

  @@index([organizationId])
  @@index([email])
  @@index([managerId])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum MonitoringMode {
  ALWAYS           // Always monitored when agent is running
  CLOCKED_IN_ONLY  // Only monitored while clocked in
  USER_CONTROLLED  // User can toggle monitoring on/off
}

enum DeviceOwnership {
  BUSINESS    // Company-owned device
  CONTRACTOR  // Contractor device
  BYOD        // Employee personal device
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// DEPARTMENTS
// ============================================

model Department {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  color          String?  // hex color for UI badges
  managerId      String?  // department head
  parentId       String?  // for nested departments
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  members      User[]       @relation("UserDepartment")
  parent       Department?  @relation("SubDepartments", fields: [parentId], references: [id])
  children     Department[] @relation("SubDepartments")
  hostGroups   HostGroup[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

// ============================================
// HOST GROUPS & DOMAIN BLOCKLISTS
// ============================================

model HostGroup {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  color          String?
  departmentId   String?  // optionally auto-assign by department
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  department   Department?     @relation(fields: [departmentId], references: [id])
  members       HostGroupMember[]
  policies      HostGroupPolicy[]
  agentPolicies AgentPolicy[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model HostGroupMember {
  id          String   @id @default(cuid())
  hostGroupId String
  deviceId    String
  addedAt     DateTime @default(now())

  hostGroup HostGroup   @relation(fields: [hostGroupId], references: [id], onDelete: Cascade)
  device    AgentDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([hostGroupId, deviceId])
}

model DomainBlocklist {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  category       String?  // e.g., "Social Media", "Gambling", "Adult", "Custom"
  domains        Json     // string[] of domains
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  policies     HostGroupPolicy[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model HostGroupPolicy {
  id              String   @id @default(cuid())
  hostGroupId     String
  blocklistId     String?  // link to domain blocklist
  policyType      PolicyType
  action          PolicyAction @default(LOG)
  // Firewall rule fields (used when policyType == FIREWALL)
  direction       String?  // "inbound" | "outbound"
  protocol        String?  // "TCP" | "UDP" | "ANY"
  port            String?  // "80", "443", "3389", "1000-2000"
  remoteAddress   String?  // IP or CIDR
  description     String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  hostGroup HostGroup        @relation(fields: [hostGroupId], references: [id], onDelete: Cascade)
  blocklist DomainBlocklist? @relation(fields: [blocklistId], references: [id])

  @@index([hostGroupId])
}

enum PolicyType {
  DOMAIN_BLOCK
  FIREWALL
}

enum PolicyAction {
  BLOCK
  LOG
  WARN
}

// ============================================
// TIME TRACKING
// ============================================

model TimeEntry {
  id             String          @id @default(cuid())
  userId         String
  organizationId String
  clockIn        DateTime
  clockOut       DateTime?
  activeSeconds  Int             @default(0)
  idleSeconds    Int             @default(0)
  breakSeconds   Int             @default(0)
  overtime       Boolean         @default(false)
  notes          String?
  status         TimeEntryStatus @default(ACTIVE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, clockIn])
  @@index([organizationId, clockIn])
}

enum TimeEntryStatus {
  ACTIVE
  COMPLETED
  EDITED
  FLAGGED
}

// ============================================
// ATTENDANCE
// ============================================

model AttendanceRecord {
  id             String           @id @default(cuid())
  userId         String
  organizationId String
  date           DateTime         @db.Date
  status         AttendanceStatus
  checkIn        DateTime?
  checkOut       DateTime?
  source         String           @default("system")
  notes          String?
  createdAt      DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([organizationId, date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  HOLIDAY
  WEEKEND
}

model LeaveRequest {
  id             String             @id @default(cuid())
  userId         String
  organizationId String
  leaveType      LeaveType
  startDate      DateTime           @db.Date
  endDate        DateTime           @db.Date
  reason         String?
  status         LeaveRequestStatus @default(PENDING)
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime           @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([organizationId, status])
}

enum LeaveType {
  ANNUAL
  SICK
  PERSONAL
  UNPAID
  MATERNITY
  PATERNITY
  OTHER
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ============================================
// ACTIVITY MONITORING
// ============================================

model ActivityEvent {
  id              String            @id @default(cuid())
  userId          String
  organizationId  String
  eventType       ActivityEventType
  appName         String?
  windowTitle     String?
  url             String?
  domain          String?
  category        String?
  durationSeconds Int?
  metadata        Json?
  timestamp       DateTime          @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, timestamp])
  @@index([organizationId, timestamp])
  @@index([domain])
}

enum ActivityEventType {
  APP_SWITCH
  WEBSITE_VISIT
  IDLE_START
  IDLE_END
  FOCUS_GAINED
  FOCUS_LOST
  HEARTBEAT
  FILE_CREATE
  FILE_DELETE
  FILE_COPY
  FILE_MOVE
  FILE_RENAME
}

model ActivitySummary {
  id                 String   @id @default(cuid())
  userId             String
  organizationId     String
  date               DateTime @db.Date
  hour               Int?
  totalActiveSeconds Int      @default(0)
  totalIdleSeconds   Int      @default(0)
  topApps            Json     @default("[]")
  topDomains         Json     @default("[]")
  productivityScore  Float?
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date, hour])
  @@index([organizationId, date])
}

// ============================================
// PROJECT MANAGEMENT
// ============================================

model Project {
  id             String        @id @default(cuid())
  organizationId String
  name           String
  description    String?
  status         ProjectStatus @default(ACTIVE)
  startDate      DateTime?     @db.Date
  endDate        DateTime?     @db.Date
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  tasks        Task[]
  milestones   Milestone[]

  @@index([organizationId])
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

model Task {
  id             String       @id @default(cuid())
  projectId      String
  organizationId String
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  assigneeId     String?
  creatorId      String
  dueDate        DateTime?    @db.Date
  estimatedHours Float?
  actualHours    Float?
  parentTaskId   String?
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator    User    @relation("TaskCreator", fields: [creatorId], references: [id])
  parentTask Task?   @relation("SubTasks", fields: [parentTaskId], references: [id])
  subTasks   Task[]  @relation("SubTasks")

  @@index([projectId, status])
  @@index([assigneeId])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  dueDate     DateTime? @db.Date
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ============================================
// SECURITY
// ============================================

model SecurityAlert {
  id             String        @id @default(cuid())
  userId         String
  organizationId String
  alertType      AlertType
  severity       AlertSeverity
  title          String
  description    String
  metadata       Json?
  status         AlertStatus   @default(OPEN)
  resolvedBy     String?
  resolvedAt     DateTime?
  createdAt      DateTime      @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

enum AlertType {
  UNUSUAL_HOURS
  EXCESSIVE_DATA_ACCESS
  UNAUTHORIZED_APP
  UNAUTHORIZED_WEBSITE
  SUSPICIOUS_TRANSFER
  POLICY_VIOLATION
  LOGIN_ANOMALY
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  DISMISSED
}

model DlpPolicy {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  rules          Json
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model AuditLog {
  id             String   @id @default(cuid())
  userId         String?
  organizationId String
  action         String
  resource       String
  resourceId     String?
  details        Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([userId])
  @@index([action])
}

// ============================================
// REPORTING
// ============================================

model ScheduledReport {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  reportType     String
  config         Json
  schedule       String
  recipients     Json
  format         String    @default("pdf")
  isActive       Boolean   @default(true)
  sendToChannel  Boolean   @default(false)  // Also post summary to Slack/Teams
  lastRunAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model ReportHistory {
  id             String   @id @default(cuid())
  organizationId String
  reportType     String
  dateFrom       DateTime
  dateTo         DateTime
  format         String   @default("pdf")
  generatedBy    String
  generatedAt    DateTime @default(now())
  fileName       String
  fileSize       Int?
  recordCount    Int      @default(0)
  summary        Json?
  status         String   @default("completed") // completed, failed

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation("generatedReports", fields: [generatedBy], references: [id])

  @@index([organizationId])
  @@index([generatedBy])
}

// ============================================
// THREAT INTELLIGENCE (IOC & CVE)
// ============================================

model IocEntry {
  id             String      @id @default(cuid())
  organizationId String
  hashType       HashType
  hashValue      String
  source         String      @default("manual")
  threatName     String?
  severity       AlertSeverity
  description    String?
  isBlocked      Boolean     @default(false)
  lastSeenAt     DateTime?
  matchCount     Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  matches  IocMatch[]

  @@unique([organizationId, hashType, hashValue])
  @@index([organizationId])
  @@index([hashValue])
}

enum HashType {
  MD5
  SHA1
  SHA256
}

model IocMatch {
  id             String   @id @default(cuid())
  iocEntryId     String
  organizationId String
  userId         String?
  hostname       String?
  filePath       String?
  processName    String?
  matchedAt      DateTime @default(now())
  metadata       Json?

  iocEntry IocEntry @relation(fields: [iocEntryId], references: [id], onDelete: Cascade)

  @@index([organizationId, matchedAt])
  @@index([iocEntryId])
}

model CveEntry {
  id             String        @id @default(cuid())
  organizationId String
  cveId          String
  severity       AlertSeverity
  cvssScore      Float?
  description    String?
  affectedSoftware String
  affectedVersions String?
  fixedVersion   String?
  remediation    String?
  status         CveStatus          @default(OPEN)
  applicability  CveApplicability   @default(UNASSESSED)
  detectedAt     DateTime           @default(now())
  resolvedAt     DateTime?
  resolvedBy     String?

  scans    CveScanResult[]
  commands RemediationCommand[]

  @@unique([organizationId, cveId, affectedSoftware])
  @@index([organizationId, status])
  @@index([organizationId, applicability])
  @@index([cveId])
}

enum CveStatus {
  OPEN
  PATCHED
  MITIGATED
  ACCEPTED
  FALSE_POSITIVE
}

enum CveApplicability {
  CONFIRMED       // Matched installed software on a device
  POTENTIAL       // Software category matches but version not confirmed
  NOT_APPLICABLE  // No devices have this software
  UNASSESSED      // Not yet checked against device inventory
}

model CveScanResult {
  id             String   @id @default(cuid())
  organizationId String
  hostname       String
  softwareName   String
  installedVersion String
  cveEntryId     String?
  scannedAt      DateTime @default(now())
  metadata       Json?

  cveEntry CveEntry? @relation(fields: [cveEntryId], references: [id])

  @@index([organizationId, scannedAt])
  @@index([hostname])
}

// ============================================
// AGENT DEVICES & REMEDIATION
// ============================================

model AgentDevice {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  hostname       String
  platform       String
  agentVersion   String       @default("0.2.0")
  status         DeviceStatus @default(ONLINE)
  lastSeenAt     DateTime     @default(now())
  ipAddress      String?
  osVersion      String?
  serialNumber   String?
  deviceOwnership DeviceOwnership @default(BUSINESS)
  installedSoftware Json?
  runningSoftware   Json?     // Currently running processes
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Hardware specs (from WinnyTool sysinfo)
  cpuName        String?
  cpuCores       Int?
  ramTotalGb     Float?
  ramAvailGb     Float?
  gpuName        String?
  diskDrives     Json?       // [{model, sizeGb, type}]
  uptimeSeconds  Int?

  // Security posture
  antivirusName  String?
  firewallStatus Json?       // {domain, private, public}
  defenderStatus String?     // "enabled" | "disabled"
  securityGrade  String?     // A+ through F

  // Windows Update status
  lastUpdateDate DateTime?
  pendingUpdates Json?       // [{title, kb}]
  updateServiceStatus String? // "running" | "stopped" | "disabled"
  rebootPending  Boolean     @default(false)

  // BSOD history
  bsodEvents     Json?       // [{timestamp, stopCode, description}]
  bsodCount      Int         @default(0)

  // Performance metrics
  performanceScore Int?
  performanceIssues Json?    // [{check, status, detail}]

  // Network
  dnsServers     String?
  networkAdapters Json?
  wifiSignal     Int?

  user     User                  @relation(fields: [userId], references: [id])
  commands RemediationCommand[]
  diagnostics DeviceDiagnostic[]
  hostGroupMemberships HostGroupMember[]
  telemetryBatches     TelemetryBatch[]
  networkConnections   NetworkConnection[]
  dnsQueryLogs         DnsQueryLog[]
  usbDeviceEvents      UsbDeviceEvent[]
  apiKey               AgentApiKey?
  supportTickets       SupportTicket[]
  mdmDevices           MdmDevice[]

  @@unique([organizationId, userId, hostname])
  @@index([organizationId])
  @@index([userId])
}

model DeviceDiagnostic {
  id             String   @id @default(cuid())
  deviceId       String
  scanType       String   // "full" | "quick" | "security" | "performance" | "network"
  timestamp      DateTime @default(now())
  results        Json     // Full scan results
  issuesFound    Int      @default(0)
  criticalCount  Int      @default(0)
  highCount      Int      @default(0)
  mediumCount    Int      @default(0)
  lowCount       Int      @default(0)
  grade          String?

  device AgentDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, timestamp])
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  STALE
}

model RemediationCommand {
  id             String        @id @default(cuid())
  organizationId String
  deviceId       String
  cveEntryId     String?
  commandType    CommandType
  command        String
  description    String?
  status         CommandStatus @default(PENDING)
  issuedBy       String
  issuedAt       DateTime      @default(now())
  executedAt     DateTime?
  result         String?
  exitCode       Int?

  device   AgentDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  cveEntry CveEntry?   @relation(fields: [cveEntryId], references: [id])

  @@index([deviceId, status])
  @@index([organizationId, issuedAt])
}

enum CommandType {
  UPDATE_SOFTWARE
  UNINSTALL_SOFTWARE
  RUN_SCRIPT
  RESTART_SERVICE
  FORCE_REBOOT
  CUSTOM
  ISOLATE_HOST
  UNISOLATE_HOST
  COLLECT_LOGS
  UPDATE_AGENT
  CHANGE_POLICY
}

enum CommandStatus {
  PENDING
  SENT
  EXECUTING
  COMPLETED
  FAILED
  CANCELLED
}

// ============================================
// AGENT API KEYS & TELEMETRY
// ============================================

model AgentApiKey {
  id             String    @id @default(cuid())
  organizationId String
  deviceId       String?   @unique
  keyHash        String    @unique
  keyPrefix      String
  name           String
  permissions    String[]
  isActive       Boolean   @default(true)
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  createdBy      String
  createdAt      DateTime  @default(now())
  revokedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  device       AgentDevice? @relation(fields: [deviceId], references: [id])

  @@index([organizationId])
  @@index([keyHash])
}

model TelemetryBatch {
  id             String   @id @default(cuid())
  organizationId String
  deviceId       String
  batchType      String
  collectedAt    DateTime
  receivedAt     DateTime @default(now())
  payload        Json
  eventCount     Int      @default(0)

  device AgentDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, batchType, collectedAt])
  @@index([organizationId, collectedAt])
}

model NetworkConnection {
  id             String   @id @default(cuid())
  organizationId String
  deviceId       String
  protocol       String
  localAddress   String
  localPort      Int
  remoteAddress  String
  remotePort     Int
  state          String
  processName    String?
  pid            Int?
  direction      String?
  timestamp      DateTime @default(now())

  device AgentDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, timestamp])
  @@index([organizationId, remoteAddress])
}

model DnsQueryLog {
  id             String   @id @default(cuid())
  organizationId String
  deviceId       String
  queryName      String
  queryType      String
  responseCode   String?
  resolvedIps    String[]
  processName    String?
  blocked        Boolean  @default(false)
  blockedBy      String?
  timestamp      DateTime @default(now())

  device AgentDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, timestamp])
  @@index([organizationId, queryName])
}

model UsbDeviceEvent {
  id             String   @id @default(cuid())
  organizationId String
  deviceId       String
  eventType      String
  vendorId       String?
  productId      String?
  serialNumber   String?
  deviceName     String
  deviceClass    String?
  allowed        Boolean  @default(true)
  timestamp      DateTime @default(now())

  device AgentDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, timestamp])
  @@index([organizationId, timestamp])
}

model AgentPolicy {
  id             String   @id @default(cuid())
  organizationId String
  hostGroupId    String?
  name           String
  policyType     String
  config         Json
  priority       Int      @default(0)
  isActive       Boolean  @default(true)
  version        Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  hostGroup    HostGroup?   @relation(fields: [hostGroupId], references: [id])

  @@index([organizationId, policyType])
}

// ============================================
// MFA & SSO
// ============================================

model MfaCredential {
  id             String   @id @default(cuid())
  userId         String
  secret         String   // encrypted TOTP secret
  verified       Boolean  @default(false)
  backupCodes    String[] // hashed backup codes
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
}

model SsoProvider {
  id             String   @id @default(cuid())
  organizationId String
  providerType   SsoProviderType
  name           String
  clientId       String
  clientSecret   String   // encrypted
  tenantId       String?  // for Entra ID
  domain         String?  // for Okta
  issuerUrl      String?
  metadataUrl    String?
  isActive       Boolean  @default(true)
  autoProvision  Boolean  @default(false) // JIT user provisioning
  defaultRole    Role     @default(EMPLOYEE)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, providerType])
  @@index([organizationId])
}

enum SsoProviderType {
  MICROSOFT_ENTRA
  OKTA
  GOOGLE_WORKSPACE
  GITHUB
}

model LoginAttempt {
  id             String   @id @default(cuid())
  email          String
  ipAddress      String?
  userAgent      String?
  success        Boolean
  failureReason  String?
  mfaRequired    Boolean  @default(false)
  mfaPassed      Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}

model ActiveSession {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  ipAddress      String?
  userAgent      String?
  lastActiveAt   DateTime @default(now())
  expiresAt      DateTime
  isRevoked      Boolean  @default(false)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
}

// ============================================
// ONBOARDING / OFFBOARDING
// ============================================

model BoardingTask {
  id             String       @id @default(cuid())
  organizationId String
  userId         String       // employee being onboarded/offboarded
  type           BoardingType // ONBOARDING or OFFBOARDING
  category       String       // e.g., "IT Setup", "HR", "Access", "Equipment"
  title          String
  description    String?
  completed      Boolean      @default(false)
  completedAt    DateTime?
  completedById  String?      // who marked it done
  dueDate        DateTime?
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user        User  @relation("BoardingUser", fields: [userId], references: [id])
  completedBy User? @relation("BoardingCompletedBy", fields: [completedById], references: [id])

  @@index([userId, type])
  @@index([organizationId, type])
}

enum BoardingType {
  ONBOARDING
  OFFBOARDING
}

// ============================================
// SUPPORT TICKETS
// ============================================

model SupportTicket {
  id             String       @id @default(cuid())
  organizationId String
  submittedBy    String       // userId of the submitter
  assignedTo     String?      // userId of assigned IT admin
  deviceId       String?      // optional linked device
  subject        String
  category       String       // e.g., "performance", "network", "access"
  reason         String?      // stock reason label
  appName        String?      // affected application
  description    String?      @db.Text
  priority       TicketPriority @default(MEDIUM)
  status         TicketStatus   @default(OPEN)
  deviceInfo     Json?        // snapshot of device info at submission time
  networkInfo    Json?        // snapshot of network info
  resolvedAt     DateTime?
  closedAt       DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // SLA tracking
  firstResponseAt  DateTime?    // when IT first replied
  slaResponseDue   DateTime?    // deadline for first response
  slaResolutionDue DateTime?    // deadline for resolution
  slaResponseBreached  Boolean  @default(false)
  slaResolutionBreached Boolean @default(false)

  // Satisfaction rating (1-5 stars, submitted by user after resolution)
  satisfactionRating  Int?       // 1-5
  satisfactionComment String?
  ratedAt             DateTime?

  submitter User            @relation("TicketSubmitter", fields: [submittedBy], references: [id])
  assignee  User?           @relation("TicketAssignee", fields: [assignedTo], references: [id])
  device    AgentDevice?    @relation(fields: [deviceId], references: [id])
  messages  TicketMessage[]

  @@index([organizationId, status])
  @@index([submittedBy])
  @@index([assignedTo])
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  message   String   @db.Text
  isInternal Boolean @default(false) // internal IT note, not visible to submitter
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id])

  @@index([ticketId, createdAt])
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_USER
  WAITING_ON_IT
  RESOLVED
  CLOSED
}

// ============================================
// MDM INTEGRATION
// ============================================

model MdmProvider {
  id             String          @id @default(cuid())
  organizationId String
  providerType   MdmProviderType
  name           String

  // Auth credentials
  clientId       String?         // Intune: Azure AD app client ID
  clientSecret   String?         // Intune: app client secret
  tenantId       String?         // Intune: Azure tenant ID
  apiToken       String?         // Jamf/Kandji: API token
  instanceUrl    String?         // Jamf/Kandji: instance URL

  isActive       Boolean         @default(true)
  autoAssign     Boolean         @default(true)
  syncIntervalMinutes Int        @default(60)
  lastSyncAt     DateTime?
  lastSyncStatus MdmSyncStatus   @default(IDLE)
  lastSyncError  String?
  lastSyncDeviceCount Int?

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id])
  mdmDevices     MdmDevice[]
  mdmActions     MdmAction[]

  @@unique([organizationId, providerType])
  @@index([organizationId])
}

model MdmDevice {
  id              String   @id @default(cuid())
  organizationId  String
  mdmProviderId   String
  mdmDeviceId     String          // ID from the MDM provider

  // Device identity (used for matching)
  serialNumber    String?
  hostname        String?
  userEmail       String?         // MDM-reported user email

  // MDM status
  enrollmentStatus   String?      // "enrolled" | "pending" | "unenrolled"
  complianceStatus   String?      // "compliant" | "noncompliant" | "unknown"
  managementState    String?      // "managed" | "unmanaged"

  // Device info from MDM
  deviceName      String?
  platform        String?         // "Windows" | "macOS" | "iOS" | "Android"
  osVersion       String?
  model           String?
  manufacturer    String?

  // MDM-managed apps
  managedApps     Json?           // [{name, version, installState}]

  // Security from MDM
  isEncrypted     Boolean?
  isJailbroken    Boolean?
  lastCheckIn     DateTime?

  // Link to MyDex
  agentDeviceId   String?
  matchedUserId   String?
  matchConfidence String?         // "serial" | "hostname" | "manual"

  rawData         Json?

  lastSyncedAt    DateTime        @default(now())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  mdmProvider     MdmProvider     @relation(fields: [mdmProviderId], references: [id], onDelete: Cascade)
  agentDevice     AgentDevice?    @relation(fields: [agentDeviceId], references: [id])

  @@unique([mdmProviderId, mdmDeviceId])
  @@index([organizationId])
  @@index([agentDeviceId])
  @@index([serialNumber])
  @@index([userEmail])
}

model MdmAction {
  id             String          @id @default(cuid())
  organizationId String
  mdmProviderId  String
  mdmDeviceId    String?
  agentDeviceId  String?

  actionType     String          // "lock" | "wipe" | "restart" | "deploy_app" | "retire" | "sync"
  payload        Json?
  status         MdmActionStatus @default(PENDING)

  issuedBy       String
  issuedAt       DateTime        @default(now())
  completedAt    DateTime?
  result         String?
  errorMessage   String?

  mdmProvider    MdmProvider     @relation(fields: [mdmProviderId], references: [id], onDelete: Cascade)

  @@index([organizationId, issuedAt])
  @@index([mdmProviderId, status])
}

enum MdmProviderType {
  MICROSOFT_INTUNE
  JAMF_PRO
  KANDJI
}

enum MdmSyncStatus {
  IDLE
  SYNCING
  SUCCESS
  FAILED
}

enum MdmActionStatus {
  PENDING
  SENT
  COMPLETED
  FAILED
  CANCELLED
}

// ─── Monitoring Change Log ──────────────────────────────────────────────────

model MonitoringChangeLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String   // The user whose monitoring settings changed
  changedById    String   // The admin/manager who made the change
  field          String   // e.g. "monitoringMode", "monitoringPaused", "canToggleMonitoring", "deviceOwnership"
  oldValue       String?
  newValue       String
  reason         String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation("MonitoringUser", fields: [userId], references: [id])
  changedBy    User         @relation("MonitoringChangedBy", fields: [changedById], references: [id])

  @@index([organizationId, createdAt])
  @@index([userId])
}

// ─── Patch Notes ────────────────────────────────────────────────────────────

model PatchNote {
  id             String   @id @default(cuid())
  organizationId String?  // null = global (system-authored), set = org-specific
  authorId       String
  version        String?  // e.g. "v0.1.0", optional
  title          String
  content        String   @db.Text
  tags           Json?    // ["feature", "bugfix", "security", ...]
  isPublished    Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  author       User          @relation("PatchNoteAuthor", fields: [authorId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
  @@index([authorId])
}

// ============================================
// COST OPTIMIZATION
// ============================================

model SoftwareLicense {
  id             String   @id @default(cuid())
  organizationId String
  application    String   // e.g. "Microsoft 365 E5"
  vendor         String?  // e.g. "Microsoft"
  totalSeats     Int
  usedSeats      Int      @default(0)
  costPerSeat    Float    // monthly cost per seat
  billingCycle   String   @default("monthly") // monthly, annual
  renewalDate    DateTime?
  category       String?  // e.g. "productivity", "security", "development"
  notes          String?  @db.Text
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model ItBudgetEntry {
  id             String   @id @default(cuid())
  organizationId String
  category       String   // "software", "hardware", "services", "personnel", "infrastructure", "other"
  description    String
  amount         Float    // dollar amount
  type           String   // "actual", "forecast", "budget"
  period         String   // "2026-01", "2026-Q1", "2026" (month, quarter, or year)
  isRecurring    Boolean  @default(false)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, period])
}

// ============================================
// SUSTAINABILITY
// ============================================

model EnergyReading {
  id             String   @id @default(cuid())
  organizationId String
  month          Int      // 1-12
  year           Int
  kwhUsed        Float
  costDollars    Float?
  source         String?  // "utility_bill", "smart_meter", "estimate"
  carbonKg       Float?   // calculated CO2 in kg (kWh * emission factor)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, month, year])
  @@index([organizationId])
}

model SustainabilityGoal {
  id             String   @id @default(cuid())
  organizationId String
  metric         String   // "energy_reduction", "carbon_reduction", "sleep_compliance", "green_score"
  targetValue    Float
  currentValue   Float    @default(0)
  unit           String   // "%", "kWh", "tCO2e", "score"
  deadline       DateTime?
  status         String   @default("active") // "active", "achieved", "missed"
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  type           String   // SECURITY_ALERT, DEVICE_OFFLINE, CLOCK_REMINDER, TICKET_UPDATE, SYSTEM, LEAVE_REQUEST, ONBOARDING
  title          String
  message        String
  link           String?  // optional link to navigate to
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([organizationId])
}

// ============================================
// PASSWORD RESET
// ============================================

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model Integration {
  id             String   @id @default(cuid())
  organizationId String
  provider       String   // "slack" | "teams"
  enabled        Boolean  @default(false)
  webhookUrl     String?
  botToken       String?
  channelId      String?
  channelName    String?
  settings       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
  @@index([organizationId])
}

// SCIM provisioning tokens for Slack/Teams directory sync
model ScimToken {
  id             String   @id @default(cuid())
  organizationId String
  provider       String   // "slack" | "teams"
  token          String   @unique
  description    String?
  isActive       Boolean  @default(true)
  lastUsedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
  @@index([organizationId])
  @@index([token])
}

// SCIM provisioning audit log
model ScimEvent {
  id             String   @id @default(cuid())
  organizationId String
  provider       String
  action         String   // "CREATE_USER" | "UPDATE_USER" | "DEACTIVATE_USER" | "REACTIVATE_USER"
  externalId     String?  // SCIM user ID from provider
  userId         String?  // Matched MyDex user ID
  email          String?
  details        Json?
  success        Boolean  @default(true)
  errorMessage   String?
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([createdAt])
}
