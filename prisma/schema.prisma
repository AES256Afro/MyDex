generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// MULTI-TENANCY & AUTH
// ============================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  projects         Project[]
  dlpPolicies      DlpPolicy[]
  scheduledReports ScheduledReport[]
}

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  name           String
  passwordHash   String?
  image          String?
  role           Role       @default(EMPLOYEE)
  status         UserStatus @default(ACTIVE)
  organizationId String
  department     String?
  jobTitle       String?
  managerId      String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  manager      User?        @relation("ManagerReports", fields: [managerId], references: [id])
  directReports User[]      @relation("ManagerReports")

  accounts          Account[]
  sessions          Session[]
  timeEntries       TimeEntry[]
  attendanceRecords AttendanceRecord[]
  leaveRequests     LeaveRequest[]
  activityEvents    ActivityEvent[]
  activitySummaries ActivitySummary[]
  assignedTasks     Task[]          @relation("TaskAssignee")
  createdTasks      Task[]          @relation("TaskCreator")
  securityAlerts    SecurityAlert[]
  auditLogs         AuditLog[]
  agentDevices      AgentDevice[]

  @@index([organizationId])
  @@index([email])
  @@index([managerId])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// TIME TRACKING
// ============================================

model TimeEntry {
  id             String          @id @default(cuid())
  userId         String
  organizationId String
  clockIn        DateTime
  clockOut       DateTime?
  activeSeconds  Int             @default(0)
  idleSeconds    Int             @default(0)
  breakSeconds   Int             @default(0)
  overtime       Boolean         @default(false)
  notes          String?
  status         TimeEntryStatus @default(ACTIVE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, clockIn])
  @@index([organizationId, clockIn])
}

enum TimeEntryStatus {
  ACTIVE
  COMPLETED
  EDITED
  FLAGGED
}

// ============================================
// ATTENDANCE
// ============================================

model AttendanceRecord {
  id             String           @id @default(cuid())
  userId         String
  organizationId String
  date           DateTime         @db.Date
  status         AttendanceStatus
  checkIn        DateTime?
  checkOut       DateTime?
  source         String           @default("system")
  notes          String?
  createdAt      DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([organizationId, date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  HOLIDAY
  WEEKEND
}

model LeaveRequest {
  id             String             @id @default(cuid())
  userId         String
  organizationId String
  leaveType      LeaveType
  startDate      DateTime           @db.Date
  endDate        DateTime           @db.Date
  reason         String?
  status         LeaveRequestStatus @default(PENDING)
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime           @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([organizationId, status])
}

enum LeaveType {
  ANNUAL
  SICK
  PERSONAL
  UNPAID
  MATERNITY
  PATERNITY
  OTHER
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ============================================
// ACTIVITY MONITORING
// ============================================

model ActivityEvent {
  id              String            @id @default(cuid())
  userId          String
  organizationId  String
  eventType       ActivityEventType
  appName         String?
  windowTitle     String?
  url             String?
  domain          String?
  category        String?
  durationSeconds Int?
  metadata        Json?
  timestamp       DateTime          @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, timestamp])
  @@index([organizationId, timestamp])
  @@index([domain])
}

enum ActivityEventType {
  APP_SWITCH
  WEBSITE_VISIT
  IDLE_START
  IDLE_END
  FOCUS_GAINED
  FOCUS_LOST
  HEARTBEAT
  FILE_CREATE
  FILE_DELETE
  FILE_COPY
  FILE_MOVE
  FILE_RENAME
}

model ActivitySummary {
  id                 String   @id @default(cuid())
  userId             String
  organizationId     String
  date               DateTime @db.Date
  hour               Int?
  totalActiveSeconds Int      @default(0)
  totalIdleSeconds   Int      @default(0)
  topApps            Json     @default("[]")
  topDomains         Json     @default("[]")
  productivityScore  Float?
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date, hour])
  @@index([organizationId, date])
}

// ============================================
// PROJECT MANAGEMENT
// ============================================

model Project {
  id             String        @id @default(cuid())
  organizationId String
  name           String
  description    String?
  status         ProjectStatus @default(ACTIVE)
  startDate      DateTime?     @db.Date
  endDate        DateTime?     @db.Date
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  tasks        Task[]
  milestones   Milestone[]

  @@index([organizationId])
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

model Task {
  id             String       @id @default(cuid())
  projectId      String
  organizationId String
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  assigneeId     String?
  creatorId      String
  dueDate        DateTime?    @db.Date
  estimatedHours Float?
  actualHours    Float?
  parentTaskId   String?
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator    User    @relation("TaskCreator", fields: [creatorId], references: [id])
  parentTask Task?   @relation("SubTasks", fields: [parentTaskId], references: [id])
  subTasks   Task[]  @relation("SubTasks")

  @@index([projectId, status])
  @@index([assigneeId])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  dueDate     DateTime? @db.Date
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ============================================
// SECURITY
// ============================================

model SecurityAlert {
  id             String        @id @default(cuid())
  userId         String
  organizationId String
  alertType      AlertType
  severity       AlertSeverity
  title          String
  description    String
  metadata       Json?
  status         AlertStatus   @default(OPEN)
  resolvedBy     String?
  resolvedAt     DateTime?
  createdAt      DateTime      @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

enum AlertType {
  UNUSUAL_HOURS
  EXCESSIVE_DATA_ACCESS
  UNAUTHORIZED_APP
  UNAUTHORIZED_WEBSITE
  SUSPICIOUS_TRANSFER
  POLICY_VIOLATION
  LOGIN_ANOMALY
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  DISMISSED
}

model DlpPolicy {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  rules          Json
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model AuditLog {
  id             String   @id @default(cuid())
  userId         String?
  organizationId String
  action         String
  resource       String
  resourceId     String?
  details        Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([userId])
  @@index([action])
}

// ============================================
// REPORTING
// ============================================

model ScheduledReport {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  reportType     String
  config         Json
  schedule       String
  recipients     Json
  format         String    @default("pdf")
  isActive       Boolean   @default(true)
  lastRunAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

// ============================================
// THREAT INTELLIGENCE (IOC & CVE)
// ============================================

model IocEntry {
  id             String      @id @default(cuid())
  organizationId String
  hashType       HashType
  hashValue      String
  source         String      @default("manual")
  threatName     String?
  severity       AlertSeverity
  description    String?
  isBlocked      Boolean     @default(false)
  lastSeenAt     DateTime?
  matchCount     Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  matches  IocMatch[]

  @@unique([organizationId, hashType, hashValue])
  @@index([organizationId])
  @@index([hashValue])
}

enum HashType {
  MD5
  SHA1
  SHA256
}

model IocMatch {
  id             String   @id @default(cuid())
  iocEntryId     String
  organizationId String
  userId         String?
  hostname       String?
  filePath       String?
  processName    String?
  matchedAt      DateTime @default(now())
  metadata       Json?

  iocEntry IocEntry @relation(fields: [iocEntryId], references: [id], onDelete: Cascade)

  @@index([organizationId, matchedAt])
  @@index([iocEntryId])
}

model CveEntry {
  id             String        @id @default(cuid())
  organizationId String
  cveId          String
  severity       AlertSeverity
  cvssScore      Float?
  description    String?
  affectedSoftware String
  affectedVersions String?
  fixedVersion   String?
  remediation    String?
  status         CveStatus     @default(OPEN)
  detectedAt     DateTime      @default(now())
  resolvedAt     DateTime?
  resolvedBy     String?

  scans    CveScanResult[]
  commands RemediationCommand[]

  @@unique([organizationId, cveId, affectedSoftware])
  @@index([organizationId, status])
  @@index([cveId])
}

enum CveStatus {
  OPEN
  PATCHED
  MITIGATED
  ACCEPTED
  FALSE_POSITIVE
}

model CveScanResult {
  id             String   @id @default(cuid())
  organizationId String
  hostname       String
  softwareName   String
  installedVersion String
  cveEntryId     String?
  scannedAt      DateTime @default(now())
  metadata       Json?

  cveEntry CveEntry? @relation(fields: [cveEntryId], references: [id])

  @@index([organizationId, scannedAt])
  @@index([hostname])
}

// ============================================
// AGENT DEVICES & REMEDIATION
// ============================================

model AgentDevice {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  hostname       String
  platform       String
  agentVersion   String       @default("0.2.0")
  status         DeviceStatus @default(ONLINE)
  lastSeenAt     DateTime     @default(now())
  ipAddress      String?
  osVersion      String?
  installedSoftware Json?
  runningSoftware   Json?     // Currently running processes
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Hardware specs (from WinnyTool sysinfo)
  cpuName        String?
  cpuCores       Int?
  ramTotalGb     Float?
  ramAvailGb     Float?
  gpuName        String?
  diskDrives     Json?       // [{model, sizeGb, type}]
  uptimeSeconds  Int?

  // Security posture
  antivirusName  String?
  firewallStatus Json?       // {domain, private, public}
  defenderStatus String?     // "enabled" | "disabled"
  securityGrade  String?     // A+ through F

  // Windows Update status
  lastUpdateDate DateTime?
  pendingUpdates Json?       // [{title, kb}]
  updateServiceStatus String? // "running" | "stopped" | "disabled"
  rebootPending  Boolean     @default(false)

  // BSOD history
  bsodEvents     Json?       // [{timestamp, stopCode, description}]
  bsodCount      Int         @default(0)

  // Performance metrics
  performanceScore Int?
  performanceIssues Json?    // [{check, status, detail}]

  // Network
  dnsServers     String?
  networkAdapters Json?
  wifiSignal     Int?

  user     User                  @relation(fields: [userId], references: [id])
  commands RemediationCommand[]
  diagnostics DeviceDiagnostic[]

  @@unique([organizationId, userId, hostname])
  @@index([organizationId])
  @@index([userId])
}

model DeviceDiagnostic {
  id             String   @id @default(cuid())
  deviceId       String
  scanType       String   // "full" | "quick" | "security" | "performance" | "network"
  timestamp      DateTime @default(now())
  results        Json     // Full scan results
  issuesFound    Int      @default(0)
  criticalCount  Int      @default(0)
  highCount      Int      @default(0)
  mediumCount    Int      @default(0)
  lowCount       Int      @default(0)
  grade          String?

  device AgentDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, timestamp])
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  STALE
}

model RemediationCommand {
  id             String        @id @default(cuid())
  organizationId String
  deviceId       String
  cveEntryId     String?
  commandType    CommandType
  command        String
  description    String?
  status         CommandStatus @default(PENDING)
  issuedBy       String
  issuedAt       DateTime      @default(now())
  executedAt     DateTime?
  result         String?
  exitCode       Int?

  device   AgentDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  cveEntry CveEntry?   @relation(fields: [cveEntryId], references: [id])

  @@index([deviceId, status])
  @@index([organizationId, issuedAt])
}

enum CommandType {
  UPDATE_SOFTWARE
  UNINSTALL_SOFTWARE
  RUN_SCRIPT
  RESTART_SERVICE
  FORCE_REBOOT
  CUSTOM
}

enum CommandStatus {
  PENDING
  SENT
  EXECUTING
  COMPLETED
  FAILED
  CANCELLED
}
